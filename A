local Fluent = loadstring(game:HttpGet("https://github.com/dawid-scripts/Fluent/releases/latest/download/main.lua"))()
-- FIXED: Added these two missing lines so SaveManager actually works
local SaveManager = loadstring(game:HttpGet("https://raw.githubusercontent.com/dawid-scripts/Fluent/master/Addons/SaveManager.lua"))()
local InterfaceManager = loadstring(game:HttpGet("https://raw.githubusercontent.com/dawid-scripts/Fluent/master/Addons/InterfaceManager.lua"))()

local Players           = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local LP  = Players.LocalPlayer
local LPN = LP.Name

-- =============================================
-- HELPERS
-- =============================================
local function GetMyPlot()
    local plots = workspace:FindFirstChild("Plots")
    if not plots then return nil end
    for _, plot in ipairs(plots:GetChildren()) do
        local owner = plot:FindFirstChild("Owner")
        if owner then
            local val = owner.Value
            if type(val) == "string" and val == LPN then return plot end
            if typeof(val) == "Instance" and val == LP then return plot end
        end
    end
    return nil
end

-- =============================================
-- WINDOW
-- =============================================
local Window = Fluent:CreateWindow({
    Title       = "Be A Streamer",
    SubTitle    = "By Oorbits",
    TabWidth    = 160,
    Size        = UDim2.fromOffset(560, 400),
    Acrylic     = true,
    Theme       = "Dark",
    MinimizeKey = Enum.KeyCode.LeftControl,
})

local Options = Fluent.Options -- Added to allow SaveManager to track values

-- =============================================
-- TAB: MAIN
-- =============================================
local MainTab = Window:AddTab({ Title = "Main", Icon = "home" })

MainTab:AddToggle("InfMoney", {
    Title       = "Dupes Money",
    Description = "Dupes money",
    Default     = false,
    Callback    = function(state)
        task.spawn(function()
            while Options.InfMoney.Value do -- Changed to use Options for better saving
                pcall(function()
                    local plot = GetMyPlot()
                    if plot then
                        local btn = plot:FindFirstChild("ActiveButtons")
                                and plot.ActiveButtons:FindFirstChild("Cheap Streaming Setup")
                                and plot.ActiveButtons["Cheap Streaming Setup"]:FindFirstChild("Button")
                        if btn and btn:FindFirstChild("TouchInterest") then
                            local hrp = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
                            if hrp then
                                firetouchinterest(btn, hrp, 0)
                                firetouchinterest(btn, hrp, 1)
                            end
                        end
                    end
                end)

                ReplicatedStorage:WaitForChild("StreamingEvent"):FireServer("startStream")

                for i = 1, 100 do
                    if not Options.InfMoney.Value then break end
                    ReplicatedStorage:WaitForChild("StreamingEvent"):FireServer("segmentStreamed")
                    task.wait(0)
                end

                ReplicatedStorage:WaitForChild("StreamingEvent"):FireServer("endStream")
                task.wait()
            end
        end)
    end,
})

MainTab:AddToggle("AutoCollect", {
    Title       = "Auto Collect",
    Default     = false,
    Callback    = function(state)
        task.spawn(function()
            while Options.AutoCollect.Value do
                pcall(function() ReplicatedStorage:WaitForChild("GetMailBox"):FireServer() end)
                task.wait(0.01)
            end
        end)
    end,
})

MainTab:AddToggle("AutoRebirth", {
    Title       = "Auto Rebirth",
    Default     = false,
    Callback    = function(state)
        task.spawn(function()
            while Options.AutoRebirth.Value do
                pcall(function() ReplicatedStorage:WaitForChild("Rebirth"):FireServer() end)
                task.wait(0.01)
            end
        end)
    end,
})

MainTab:AddToggle("AutoBuy", {
    Title       = "Auto Buy",
    Default     = false,
    Callback    = function(state)
        task.spawn(function()
            while Options.AutoBuy.Value do
                local plot = GetMyPlot()
                if plot then
                    local activeButtons = plot:FindFirstChild("ActiveButtons")
                    if activeButtons then
                        for _, item in ipairs(activeButtons:GetChildren()) do
                            if not Options.AutoBuy.Value then break end
                            local button = item:FindFirstChild("Button")
                            if button then
                                local hrp = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
                                if hrp and button:FindFirstChild("TouchInterest") then
                                    firetouchinterest(button, hrp, 0)
                                    firetouchinterest(button, hrp, 1)
                                end
                            end
                        end
                    end
                end
                task.wait(0.5)
            end
        end)
    end,
})

