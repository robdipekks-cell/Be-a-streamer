-- // Fluent GUI Script

local Fluent            = loadstring(game:HttpGet("https://github.com/dawid-scripts/Fluent/releases/latest/download/main.lua"))()
local Players           = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local LP  = Players.LocalPlayer
local LPN = LP.Name

-- =============================================
-- HELPERS
-- =============================================

-- Find the plot whose Owner value matches the local player
-- Handles both StringValue (Value = "username") and ObjectValue (Value = Player)
local function GetMyPlot()
    local plots = workspace:FindFirstChild("Plots")
    if not plots then return nil end
    for _, plot in ipairs(plots:GetChildren()) do
        local owner = plot:FindFirstChild("Owner")
        if owner then
            local val = owner.Value
            -- StringValue: Value is the username string directly
            if type(val) == "string" and val == LPN then
                return plot
            end
            -- ObjectValue: Value is the Player instance
            if typeof(val) == "Instance" and val == LP then
                return plot
            end
        end
    end
    return nil
end

-- =============================================
-- WINDOW
-- =============================================

local Window = Fluent:CreateWindow({
    Title       = "Be A Streamer",
    SubTitle    = "By Oorbits",
    TabWidth    = 160,
    Size        = UDim2.fromOffset(560, 400),
    Acrylic     = true,
    Theme       = "Dark",
    MinimizeKey = Enum.KeyCode.LeftControl,
})

-- =============================================
-- TAB: MAIN
-- =============================================
local MainTab = Window:AddTab({ Title = "Main", Icon = "home" })

-- ── Inf Money ────────────────────────────────
local infMoneyOn = false

MainTab:AddToggle("InfMoney", {
    Title       = "Dupes Money",
    Description = "Dupes money",
    Default     = false,
    Callback    = function(state)
        infMoneyOn = state
        if not state then return end
        task.spawn(function()
            while infMoneyOn do
                -- 0) Touch the Cheap Streaming Setup button first
                pcall(function()
                    local plot = GetMyPlot()
                    if plot then
                        local btn = plot:FindFirstChild("ActiveButtons")
                                and plot.ActiveButtons:FindFirstChild("Cheap Streaming Setup")
                                and plot.ActiveButtons["Cheap Streaming Setup"]:FindFirstChild("Button")
                        if btn and btn:FindFirstChild("TouchInterest") then
                            local hrp = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
                            if hrp then
                                firetouchinterest(btn, hrp, 0)
                                firetouchinterest(btn, hrp, 1)
                            end
                        end
                    end
                end)

                -- 1) startStream
                pcall(function()
                    ReplicatedStorage:WaitForChild("StreamingEvent"):FireServer("startStream")
                end)

                -- 2) segmentStreamed × 100 in one second
                for i = 1, 100 do
                    if not infMoneyOn then break end
                    pcall(function()
                        ReplicatedStorage:WaitForChild("StreamingEvent"):FireServer("segmentStreamed")
                    end)
                    task.wait(0)
                end

                -- 3) endStream then immediately loop
                pcall(function()
                    ReplicatedStorage:WaitForChild("StreamingEvent"):FireServer("endStream")
                end)

                -- 0 second gap before next loop
                task.wait()
            end
        end)
    end,
})

