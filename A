-- ── Auto Buy ──────────────────────────────────
local autoBuyOn = false

MainTab:AddToggle("AutoBuy", {
    Title       = "Auto Buy",
    Description = "Buy all buttons in your plot.",
    Default     = false,
    Callback    = function(state)
        autoBuyOn = state
        if not state then return end
        task.spawn(function()
            while autoBuyOn do
                local plot = GetMyPlot()
                if plot then
                    local activeButtons = plot:FindFirstChild("ActiveButtons")
                    if activeButtons then
                        for _, item in ipairs(activeButtons:GetChildren()) do
                            if not autoBuyOn then break end
                            -- Each item has a Button child with a TouchInterest
                            local button = item:FindFirstChild("Button")
                            if button then
                                local char = LP.Character
                                local hrp  = char and char:FindFirstChild("HumanoidRootPart")
                                if hrp and button:FindFirstChild("TouchInterest") then
                                    pcall(function()
                                        firetouchinterest(button, hrp, 0) -- touch begin
                                        firetouchinterest(button, hrp, 1) -- touch end
                                    end)
                                end
                            end
                        end
                    end
                end
                task.wait(0)
            end
        end)
    end,
})

